---
import '../styles/global.css';
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bangun Jaya - Toko Bahan Bangunan</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar-inner">
        <span>☎ (021) 1234 5678</span>
        <span>💬 0857 1234 5678</span>
        <span>🕘 Senin - Sabtu: 08.00 - 17.00</span>
      </div>
    </header>

    <nav class="navbar">
      <div class="container nav-inner">
        <a href="#" class="logo">
          <span class="logo-mark">B</span>
          <span>
            <strong>BANGUN JAYA</strong>
            <small>TOKO BAHAN BANGUNAN</small>
          </span>
        </a>

        <button class="menu-toggle" id="menuToggle" type="button" aria-label="Buka menu">☰</button>

        <div class="nav-menu" id="navMenu">
          <a class="active" href="#home">Beranda</a>
          <a href="#about">Tentang Kami</a>
          <a href="#products">Produk</a>
          <a href="#projects">Proyek</a>
          <a href="#advantages">Keunggulan</a>
          <a href="#contact">Kontak</a>
        </div>

        <a class="btn btn-red nav-cta" href="https://wa.me/6285712345678" target="_blank" rel="noreferrer">
          Chat WhatsApp
        </a>
      </div>
    </nav>

    <main>
      <section class="hero" id="home">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <span class="badge">TOKO BAHAN BANGUNAN TERPERCAYA</span>
          <h1>Mitra Terpercaya untuk Kebutuhan <span>Bangunan Anda</span></h1>
          <p>Menyediakan material bangunan berkualitas untuk proyek rumah, ruko, hingga industri.</p>
          <div class="hero-actions">
            <a href="#contact" class="btn btn-red">Hubungi Kami</a>
            <a href="#products" class="btn btn-outline">Lihat Produk</a>
          </div>
        </div>
      </section>

      <section class="feature-strip container">
        <div class="feature-item">
          <b>🛡️ Produk Berkualitas</b>
          <span>Material terjamin kualitasnya</span>
        </div>
        <div class="feature-item">
          <b>📦 Stok Lengkap</b>
          <span>Tersedia banyak pilihan</span>
        </div>
        <div class="feature-item">
          <b>🚚 Pengiriman Cepat</b>
          <span>Jangkauan luas & aman</span>
        </div>
        <div class="feature-item">
          <b>👷 Layanan Profesional</b>
          <span>Siap membantu Anda</span>
        </div>
      </section>

      <section class="about section" id="about">
        <div class="container about-grid">
          <div class="about-image">
            <div class="photo-card main-photo"></div>
            <div class="experience">
              <strong>20+</strong>
              <span>Tahun<br />Pengalaman</span>
            </div>
          </div>
          <div class="about-text">
            <p class="section-label">TENTANG KAMI</p>
            <h2>Melayani dengan Komitmen, Membangun dengan <span>Kualitas</span></h2>
            <p>
              Toko Bangunan Bangun Jaya telah berdiri sejak tahun 2003 dan terus berkomitmen
              menyediakan material bangunan terbaik dengan harga kompetitif serta pelayanan yang
              memuaskan.
            </p>
            <div class="stats-grid">
              <div>
                <b>10.000+</b>
                <span>Pelanggan Terpercaya</span>
              </div>
              <div>
                <b>500+</b>
                <span>Proyek Selesai</span>
              </div>
              <div>
                <b>50+</b>
                <span>Brand Berkualitas</span>
              </div>
              <div>
                <b>Jabodetabek</b>
                <span>Jangkauan Area</span>
              </div>
            </div>
            <a class="btn btn-blue" href="#contact">Selengkapnya Tentang Kami →</a>
          </div>
        </div>
      </section>

      <section class="section products" id="products">
        <div class="container">
          <p class="section-label center">PRODUK KAMI</p>
          <h2 class="center-title">Tersedia Berbagai Kebutuhan <span>Material Bangunan</span></h2>
          <div class="product-grid">
            <article class="product-card">
              <div class="product-img img-semen"></div>
              <div class="icon">🧱</div>
              <h3>Semen & Bahan Bangunan</h3>
              <p>Semen, pasir, batako, bata merah, hebel, dan lainnya.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
            <article class="product-card">
              <div class="product-img img-cat"></div>
              <div class="icon">🎨</div>
              <h3>Cat & Pelapis</h3>
              <p>Cat tembok, cat kayu, waterproofing, dan pelapis.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
            <article class="product-card">
              <div class="product-img img-sanitari"></div>
              <div class="icon">🚿</div>
              <h3>Sanitari & Plumbing</h3>
              <p>Kloset, wastafel, kran, pipa, pompa air, dan perlengkapan.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
            <article class="product-card">
              <div class="product-img img-listrik"></div>
              <div class="icon">⚡</div>
              <h3>Listrik & Elektrikal</h3>
              <p>Kabel, saklar, lampu, MCB, panel, dan alat listrik.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
            <article class="product-card">
              <div class="product-img img-tools"></div>
              <div class="icon">🛠️</div>
              <h3>Perkakas & Aksesoris</h3>
              <p>Alat pertukangan, mesin, sekrup, paku, dan aksesoris.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
            <article class="product-card">
              <div class="product-img img-atap"></div>
              <div class="icon">🏠</div>
              <h3>Atap & Baja Ringan</h3>
              <p>Genteng, baja ringan, spandek, talang, dan rangka.</p>
              <a href="#contact">Lihat Selengkapnya →</a>
            </article>
          </div>
        </div>
      </section>

      <section class="advantages" id="advantages">
        <div class="container advantages-grid">
          <div>
            <b>🛡️ Harga Bersaing</b>
            <span>Harga terbaik untuk kualitas terbaik</span>
          </div>
          <div>
            <b>📦 Stok Lengkap</b>
            <span>Pilihan material lengkap dalam satu tempat</span>
          </div>
          <div>
            <b>👷 Konsultasi Gratis</b>
            <span>Tim berpengalaman siap membantu</span>
          </div>
          <div>
            <b>🚚 Pengiriman Cepat</b>
            <span>Armada sendiri & mitra pengiriman terpercaya</span>
          </div>
          <div>
            <b>🛒 Belanja Mudah</b>
            <span>Proses cepat, praktis, dan aman</span>
          </div>
        </div>
      </section>

      <section class="section projects" id="projects">
        <div class="container">
          <p class="section-label center">PROYEK KAMI</p>
          <h2 class="center-title">Telah Mendukung Berbagai Proyek <span>Berskala Besar & Kecil</span></h2>
          <div class="project-grid">
            <article>
              <div class="project-img p1"></div>
              <b>Perumahan Citra Indah</b>
              <span>Cileungsi</span>
            </article>
            <article>
              <div class="project-img p2"></div>
              <b>Ruko Grand Media</b>
              <span>Bekasi</span>
            </article>
            <article>
              <div class="project-img p3"></div>
              <b>Sekolah Islam Terpadu</b>
              <span>Depok</span>
            </article>
            <article>
              <div class="project-img p4"></div>
              <b>Gudang Logistik</b>
              <span>Karawang</span>
            </article>
            <article>
              <div class="project-img p5"></div>
              <b>Apartemen The Suites</b>
              <span>Jakarta</span>
            </article>
          </div>
          <div class="center">
            <a class="btn btn-blue" href="#contact">Lihat Semua Proyek →</a>
          </div>
        </div>
      </section>

      <section class="cta container" id="contact">
        <div>
          <h2>Butuh Material Bangunan untuk Proyek Anda?</h2>
          <p>Konsultasikan kebutuhan Anda sekarang juga.</p>
        </div>
        <a class="btn btn-light" href="https://wa.me/6285712345678" target="_blank" rel="noreferrer">
          Chat WhatsApp Sekarang
        </a>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-grid">
        <div>
          <h3>BANGUN JAYA</h3>
          <p>Menyediakan material bangunan berkualitas dengan pelayanan terbaik.</p>
        </div>
        <div>
          <h4>Quick Links</h4>
          <a href="#home">Beranda</a>
          <a href="#about">Tentang Kami</a>
          <a href="#products">Produk</a>
          <a href="#projects">Proyek</a>
        </div>
        <div>
          <h4>Produk</h4>
          <a>Semen & Bahan Bangunan</a>
          <a>Cat & Pelapis</a>
          <a>Sanitari & Plumbing</a>
          <a>Listrik & Elektrikal</a>
        </div>
        <div>
          <h4>Kontak Kami</h4>
          <p>Jl. Raya Industri No. 88<br />Cikarang, Bekasi 17530</p>
          <p>☎ (021) 1234 5678<br />💬 0857 1234 5678</p>
        </div>
      </div>
      <p class="copyright">© 2026 Bangun Jaya. Semua Hak Dilindungi.</p>
    </footer>

    <button class="back-top" id="backTop" type="button" aria-label="Kembali ke atas">↑</button>

    <script is:inline>
      const menuToggle = document.getElementById('menuToggle');
      const navMenu = document.getElementById('navMenu');
      const backTop = document.getElementById('backTop');

      menuToggle?.addEventListener('click', () => {
        navMenu?.classList.toggle('open');
      });

      navMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => navMenu.classList.remove('open'));
      });

      window.addEventListener('scroll', () => {
        backTop?.classList.toggle('show', window.scrollY > 500);
      });

      backTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
